# Core
SECRET_KEY=change-me
DEBUG=False
DURIELBIZ_ALLOWED_HOSTS=127.0.0.1,localhost,durieltech.pythonanywhere.com
DURIELBIZ_CSRF_TRUSTED_ORIGINS=https://durieltech.pythonanywhere.com

# Email / admin alerts
ADMIN_NAME=DurielTech Admin
ADMIN_EMAIL=info@durieltech.com.ng
DEFAULT_FROM_EMAIL=info@durieltech.com.ng
SERVER_EMAIL=info@durieltech.com.ng
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=info@durieltech.com.ng
EMAIL_HOST_PASSWORD=ENC(paste-encrypted-value-here)
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=20

